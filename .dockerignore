# ── Python cache & compiled files ────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyd
*.pyo
.pytest_cache/

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
.env

# ── IDE and OS files ──────────────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp

# ── Git ───────────────────────────────────────────────────────────────────────
.git/
.gitignore

# ── Large raw data (models/ and data/ are mounted as volumes) ─────────────────
# We exclude them from the build context since they're bind-mounted at runtime.
# Remove these lines if you want to bake models into the image directly.
models/
data/

# ── Notebooks & scratch ───────────────────────────────────────────────────────
*.ipynb
.ipynb_checkpoints/
notebooks/
scratch/
tmp/

# ── Logs & results ────────────────────────────────────────────────────────────
*.log
results/*.png
results/*.txt

# ── Existing Docker files (no recursive Docker builds) ───────────────────────
Dockerfile
docker-compose.yml
.dockerignore

# ── Misc ──────────────────────────────────────────────────────────────────────
*.egg-info/
dist/
build/
